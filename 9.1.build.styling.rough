```
You are updating Cench Studio's style system so that visual style
presets automatically drive renderer choice, roughness, texture
overlays, and drawing tool defaults. Currently these are all manual
decisions. After this change, picking a style preset configures
everything automatically.

No new libraries needed. You already have:
  - generateTextureCanvas() in /lib/canvas-renderer/index.ts
  - ROUGHNESS global injected into scene templates
  - Rough.js loaded in canvas2d scene template
  - Tool presets (marker, pen, chalk, brush) in the renderer
  - bgStyle, defaultTool in GlobalStyle type

---

## PART 1 — STYLE PRESET DEFINITIONS

Create /lib/styles/presets.ts:

```ts
export type StylePresetId =
  | 'whiteboard'
  | 'chalkboard'
  | 'blueprint'
  | 'clean'
  | 'data-story'
  | 'newspaper'
  | 'neon'
  | 'kraft'

export interface StylePreset {
  id: StylePresetId
  name: string
  description: string
  emoji: string

  // Visual output config
  palette: [string, string, string, string]
  bgColor: string
  bgStyle: 'plain' | 'paper' | 'grid' | 'dots' | 'chalkboard' | 'kraft'
  font: 'Caveat' | 'DM Mono' | 'Georgia' | 'monospace'

  // Renderer preferences
  preferredRenderer: 'canvas2d' | 'svg' | 'auto'
  // 'auto' = agent decides per scene
  // 'canvas2d' = strongly prefer canvas2d (organic content)
  // 'svg' = strongly prefer svg (technical/precise content)

  // Drawing character
  roughnessLevel: number       // 0 = clean, 3 = very rough
  defaultTool: 'marker' | 'pen' | 'chalk' | 'brush' | 'highlighter'
  strokeColorOverride: string | null
  // null = use palette[0]
  // string = override (e.g. '#fffef9' for chalk on dark bg)

  // Texture overlay (applied automatically after canvas2d renders)
  textureStyle: 'none' | 'grain' | 'paper' | 'chalk' | 'lines'
  textureIntensity: number     // 0-1, amount of texture
  textureBlendMode: 'multiply' | 'screen' | 'overlay'

  // D3/data scenes
  axisColor: string            // color for chart axes/labels
  gridColor: string            // color for chart grid lines

  // Agent instruction (injected into scene generation prompts)
  agentGuidance: string
}

export const STYLE_PRESETS: Record<StylePresetId, StylePreset> = {

  whiteboard: {
