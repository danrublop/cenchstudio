// Helper: get preset by id (with fallback)
export function getPreset(id: StylePresetId): StylePreset {
  return STYLE_PRESETS[id] ?? STYLE_PRESETS.whiteboard;
}

// Resolve effective style from preset + any overrides
export function resolveStyle(
  presetId: StylePresetId,
  overrides: Partial<GlobalStyle> = {}
): ResolvedStyle {
  const preset = getPreset(presetId);
  return {
    ...preset,
    ...overrides,
    // Never let overrides break critical preset behaviors
    strokeColor: overrides.strokeColorOverride
      ?? preset.strokeColorOverride
      ?? preset.palette[0],
  };
}

export interface ResolvedStyle extends StylePreset {
  strokeColor: string   // the actual stroke color to use
}
```

