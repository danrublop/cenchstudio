## PART 3 — UPDATE writeSceneHTML

In /lib/scene-html/generator.ts, update all template functions
to read from the resolved style preset:

```ts
import { resolveStyle, StylePresetId } from '../styles/presets';
import { generateTextureCanvas } from '../canvas-renderer';

export async function writeSceneHTML(
  scene: Scene,
  globalStyle: GlobalStyle
): Promise<string> {
  // Resolve preset into concrete style values
  const style = resolveStyle(
    globalStyle.presetId ?? 'whiteboard',
    {
      paletteOverride: globalStyle.paletteOverride ?? undefined,
      bgColorOverride: globalStyle.bgColorOverride ?? undefined,
      fontOverride: globalStyle.fontOverride ?? undefined,
    }
  );

  // Apply scene-level style override on top
  const sceneStyle = scene.styleOverride
    ? { ...style, ...scene.styleOverride }
    : style;

  switch (scene.renderer ?? inferRenderer(scene, sceneStyle)) {
    case 'canvas2d': return renderCanvas2DTemplate(scene, sceneStyle);
    case 'svg':      return renderSVGTemplate(scene, sceneStyle);
    // etc
  }
}

// Infer renderer from style preset if not explicitly set
function inferRenderer(scene: Scene, style: ResolvedStyle): string {
  if (style.preferredRenderer === 'auto') {
    // Fall back to scene type
    if (scene.layers.some(l => l.type === 'd3')) return 'd3';
    if (scene.layers.some(l => l.type === 'three')) return 'three';
    return 'canvas2d';
  }
  return style.preferredRenderer;
}
```

### Canvas2D template — automatic texture overlay

In renderCanvas2DTemplate(), after the scene code block,
automatically inject texture overlay code based on style:

```ts
function renderCanvas2DTemplate(scene: Scene, style: ResolvedStyle): string {
  const useTexture = style.textureStyle !== 'none';
  const useRoughJs = style.roughnessLevel > 0;

  return `<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      width: 1920px;
      height: 1080px;
      overflow: hidden;
      background: ${style.bgColor};
      ${style.bgStyle === 'grid' ? `
        background-image:
          linear-gradient(${style.gridColor} 1px, transparent 1px),
          linear-gradient(90deg, ${style.gridColor} 1px, transparent 1px);
        background-size: 40px 40px;
      ` : ''}
      ${style.bgStyle === 'dots' ? `
        background-image: radial-gradient(
          circle, ${style.gridColor} 1px, transparent 1px
        );
        background-size: 40px 40px;
      ` : ''}
    }
  </style>
  ${useRoughJs
    ? `<script src="https://unpkg.com/roughjs@4.6.6/bundled/rough.js"></script>`
    : ''}
</head>
<body>
  ${renderVideoLayer(scene)}
  <canvas id="main-canvas" width="1920" height="1080"
    style="display:block; position:absolute; inset:0;"></canvas>
  <canvas id="texture-canvas" width="1920" height="1080"
    style="display:block; position:absolute; inset:0; pointer-events:none;
           mix-blend-mode:${style.textureBlendMode}; opacity:${style.textureIntensity};
           ${useTexture ? '' : 'display:none;'}"></canvas>
  ${renderOtherLayers(scene)}

  <script>
    // ── Global constants ──────────────────────────────────
    const PALETTE   = ${JSON.stringify(style.palette)};
    const DURATION  = ${scene.duration};
    const ROUGHNESS = ${style.roughnessLevel};
    const FONT      = '${style.font}';
    const WIDTH     = 1920;
    const HEIGHT    = 1080;
    const TOOL      = '${style.defaultTool}';
    const STROKE_COLOR = '${style.strokeColor}';
    // STROKE_COLOR is the preset's default stroke color.
    // Use PALETTE[N] for accent colors.
    // Use STROKE_COLOR for primary content strokes.

    // ── mulberry32 seeded random ──────────────────────────
    function mulberry32(seed) {
      return function() {
        seed |= 0; seed = seed + 0x6D2B79F5 | 0;
        let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
        t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
        return ((t ^ t >>> 14) >>> 0) / 4294967296;
      }
    }

    // ── Canvas renderer utilities (inlined) ───────────────
    ${inlinedCanvasRenderer}

    // ── Drawing tool defaults ─────────────────────────────
    // The TOOL and ROUGHNESS constants are automatically set
    // from the project style preset. When calling animateRough*
    // functions, you may omit tool and roughness — they default
    // to the preset values:
    //
    //   animateRoughLine(ctx, x1,y1,x2,y2, {
    //     color: STROKE_COLOR,
    //     seed: 1,
    //     // tool and roughness inherited from preset
    //   }, 600)
    //
    // Override only when you need a different feel for a specific element.

    // ── Seek mode ─────────────────────────────────────────
    const SEEK_TIME = parseFloat(
      new URLSearchParams(location.search).get('t') || '0'
    );

    // ── Scene code ────────────────────────────────────────
    ${scene.layers.map(l => `
      // Layer: ${l.label} (${l.type})
      setTimeout(async () => {
        ${l.generatedCode}
      }, ${getAbsoluteStartAt(l, scene.layers) * 1000});
    `).join('\n')}

    // ── Automatic texture overlay ─────────────────────────
    // Applied after all layers finish rendering.
    // Controlled by style preset — not by scene code.
    ${useTexture ? `
    (function applyTextureOverlay() {
      const textureCanvas = document.getElementById('texture-canvas');
      if (!textureCanvas) return;
      const ctx = textureCanvas.getContext('2d');
      const rand = mulberry32(${hashString(scene.id)});

      ${style.textureStyle === 'grain' ? `
        const imageData = ctx.createImageData(1920, 1080);
        for (let i = 0; i < imageData.data.length; i += 4) {
          const noise = rand() * 255;
          imageData.data[i]   = noise;
          imageData.data[i+1] = noise;
          imageData.data[i+2] = noise;
          imageData.data[i+3] = rand() * 255;
        }
        ctx.putImageData(imageData, 0, 0);
      ` : ''}

      ${style.textureStyle === 'paper' ? `
        for (let x = 0; x < 1920; x += 1.5) {
          for (let y = 0; y < 1080; y += 1.5) {
            const v = rand();
            ctx.fillStyle = \`rgba(0,0,0,\${v})\`;
            ctx.fillRect(x, y, 1.5, 1.5);
          }
        }
      ` : ''}

      ${style.textureStyle === 'chalk' ? `
        for (let y = 0; y < 1080; y += 2) {
          ctx.beginPath();
          ctx.strokeStyle = \`rgba(255,255,255,\${rand() * 0.3})\`;
          ctx.lineWidth = 1 + rand() * 2;
          ctx.moveTo(0, y + rand() * 2);
          for (let x = 0; x < 1920; x += 20) {
            ctx.lineTo(x, y + (rand() - 0.5) * 4);
          }
          ctx.stroke();
        }
      ` : ''}

      ${style.textureStyle === 'lines' ? `
        for (let y = 0; y < 1080; y += 28) {
          ctx.beginPath();
          ctx.strokeStyle = \`rgba(0,0,0,0.06)\`;
          ctx.lineWidth = 0.5;
          ctx.moveTo(0, y);
          ctx.lineTo(1920, y);
          ctx.stroke();
        }
      ` : ''}
    })();
    ` : '// No texture overlay for this style preset'}

    // ── getTotalLength for SVG strokes ────────────────────
    document.querySelectorAll('.stroke').forEach(el => {
      if (el.getTotalLength) {
        el.style.setProperty('--len', el.getTotalLength());
      }
    });
  </script>
</body>
</html>`;
}
```

### SVG template — automatic roughness post-processing

In renderSVGTemplate(), apply Rough.js post-processing
based on preset roughnessLevel:

```ts
function renderSVGTemplate(scene: Scene, style: ResolvedStyle): string {
  const svgContent = buildSVGContent(scene, style);

  // Apply roughness post-processing if preset calls for it
  const processedSVG = style.roughnessLevel > 0.2
    ? roughenSVG(svgContent, style.roughnessLevel, scene.id)
    : svgContent;

  return `<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; }
    body {
      width:1920px; height:1080px; overflow:hidden;
      background:${style.bgColor};
      ${buildBgStyleCSS(style)}
    }
    .stroke {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: var(--len, 1000);
      stroke-dashoffset: var(--len, 1000);
      animation: draw var(--dur, 1s) ease-in-out var(--delay, 0s) forwards;
    }
    .fadein {
      opacity: 0;
      animation: pop var(--dur, 0.4s) ease var(--delay, 0s) forwards;
    }
    @keyframes draw { to { stroke-dashoffset: 0; } }
    @keyframes pop  { to { opacity: 1; } }
  </style>
  ${style.roughnessLevel > 0.2
    ? '<script src="https://unpkg.com/roughjs@4.6.6/bundled/rough.js"></script>'
    : ''}
</head>
<body>
  ${renderVideoLayer(scene)}
  <div style="position:absolute;inset:0;">
    ${processedSVG}
  </div>
  <script>
    const PALETTE = ${JSON.stringify(style.palette)};
    const DURATION = ${scene.duration};
    const ROUGHNESS = ${style.roughnessLevel};
    document.querySelectorAll('.stroke').forEach(el => {
      if (el.getTotalLength) {
        el.style.setProperty('--len', el.getTotalLength());
      }
    });
  </script>
</body>
</html>`;
}

function buildBgStyleCSS(style: ResolvedStyle): string {
  switch (style.bgStyle) {
    case 'grid':
      return `
        background-image:
          linear-gradient(${style.gridColor} 1px, transparent 1px),
          linear-gradient(90deg, ${style.gridColor} 1px, transparent 1px);
        background-size: 40px 40px;`;
    case 'dots':
      return `
        background-image: radial-gradient(
          circle, ${style.gridColor} 1.5px, transparent 1.5px
        );
        background-size: 40px 40px;`;
    default:
      return '';
  }
}

// Deterministic hash of scene id for texture seed
function hashString(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}
```

