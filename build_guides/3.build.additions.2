## PART 1 — PROJECT-LEVEL OUTPUT MODE

### 1.1 Project Model

Add a top-level project concept to the Zustand store. 
Currently the store just has a flat list of scenes. 
Wrap it in a project:

```ts
interface Project {
  id: string
  name: string
  outputMode: 'mp4' | 'interactive'
  createdAt: string
  updatedAt: string
  
  // MP4 mode settings
  mp4Settings: {
    resolution: '720p' | '1080p' | '4k'
    fps: 24 | 30 | 60
    format: 'mp4' | 'webm'
  }
  
  // Interactive mode settings
  interactiveSettings: {
    playerTheme: 'dark' | 'light' | 'transparent'
    showProgressBar: boolean
    showSceneNav: boolean
    allowFullscreen: boolean
    brandColor: string        // accent color for player chrome
    customDomain: string | null
    password: string | null   // optional password protection
  }
  
  // Scene graph (works for both modes)
  // In MP4 mode: scenes play linearly in order
  // In interactive mode: scenes can branch
  scenes: Scene[]
  sceneGraph: SceneGraph     // defines connections between scenes
}

interface SceneGraph {
  nodes: SceneNode[]
  edges: SceneEdge[]
  startSceneId: string
}

interface SceneNode {
  id: string           // matches scene.id
  position: { x: number, y: number }  // for graph editor UI
}

interface SceneEdge {
  id: string
  fromSceneId: string
  toSceneId: string
  condition: EdgeCondition
}

interface EdgeCondition {
  type: 'auto'          // plays next automatically after scene ends
       | 'hotspot'      // user clicks a hotspot
       | 'choice'       // user selects from multiple options
       | 'quiz'         // user answers correctly
       | 'gate'         // user clicks Continue button
       | 'variable'     // branch based on a variable value
  
  // For hotspot/choice/quiz: which interaction element triggers this edge
  interactionId: string | null
  
  // For variable branching
  variableName: string | null
  variableValue: string | null
}
```

