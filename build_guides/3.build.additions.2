## PART 2 — INTERACTION ELEMENTS

### 2.1 Interaction Element Model

Add to Scene:

```ts
interface Scene {
  // ... existing fields ...
  interactions: InteractionElement[]
  variables: SceneVariable[]    // variables set/read in this scene
}

type InteractionElement =
  | HotspotElement
  | ChoiceElement
  | QuizElement
  | GateElement
  | TooltipElement
  | FormInputElement

interface BaseInteraction {
  id: string
  type: string
  // Position as % of canvas (0-100)
  x: number
  y: number
  width: number
  height: number
  // When this element appears (seconds into scene)
  appearsAt: number
  // Optional: hide after N seconds (null = stays until scene ends)
  hidesAt: number | null
  // Animation for appearance
  entranceAnimation: 'fade' | 'slide-up' | 'pop' | 'none'
}

interface HotspotElement extends BaseInteraction {
  type: 'hotspot'
  label: string
  shape: 'circle' | 'rectangle' | 'pill'
  style: 'pulse' | 'glow' | 'border' | 'filled'
  color: string
  // Which edge in sceneGraph this triggers (set when connecting in graph)
  triggersEdgeId: string | null
  // Or: jump to specific scene directly
  jumpsToSceneId: string | null
}

interface ChoiceElement extends BaseInteraction {
  type: 'choice'
  question: string | null     // optional question above buttons
  layout: 'horizontal' | 'vertical' | 'grid'
  options: ChoiceOption[]
}

interface ChoiceOption {
  id: string
  label: string
  icon: string | null         // emoji or lucide icon name
  jumpsToSceneId: string
  color: string | null        // override button color
}

interface QuizElement extends BaseInteraction {
  type: 'quiz'
  question: string
  options: QuizOption[]
  correctOptionId: string
  onCorrect: 'continue' | 'jump'
  onCorrectSceneId: string | null
  onWrong: 'retry' | 'jump' | 'continue'
  onWrongSceneId: string | null
  explanation: string | null   // shown after answering
}

interface QuizOption {
  id: string
  label: string
}

interface GateElement extends BaseInteraction {
  type: 'gate'
  // Scene auto-pauses at appearsAt and shows this button
  buttonLabel: string         // default "Continue →"
  buttonStyle: 'primary' | 'outline' | 'minimal'
  // Optionally require a minimum time before gate appears
  minimumWatchTime: number    // seconds (0 = immediate)
}

interface TooltipElement extends BaseInteraction {
  type: 'tooltip'
  // The trigger area (hotspot that shows tooltip on hover)
  triggerShape: 'circle' | 'rectangle'
  triggerColor: string
  triggerLabel: string | null
  // The tooltip content
  tooltipTitle: string
  tooltipBody: string
  tooltipPosition: 'top' | 'bottom' | 'left' | 'right'
  tooltipMaxWidth: number     // px
}

interface FormInputElement extends BaseInteraction {
  type: 'form'
  fields: FormField[]
  submitLabel: string         // default "Continue"
  // Variables set from this form (available in subsequent scenes)
  setsVariables: { fieldId: string, variableName: string }[]
  jumpsToSceneId: string | null
}

interface FormField {
  id: string
  label: string
  type: 'text' | 'select' | 'radio'
  placeholder: string | null
  options: string[]           // for select/radio
  required: boolean
}

interface SceneVariable {
  name: string
  // Variables can be displayed in scene content via {varName} tokens
  // Claude should be prompted to use these in generated content
}
```

