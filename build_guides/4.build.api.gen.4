### 2.4 Background removal

Use fal.ai's BRIA RMBG model (fast, high quality, handles hair well):

```ts
// /lib/apis/background-removal.ts
import * as fal from '@fal-ai/serverless-client';

export async function removeVideoBackground(
  videoPath: string,
  outputPath: string
): Promise<void> {
  // Strategy: extract frames, remove bg per frame, reassemble
  // For video: use ffmpeg to extract PNG frames
  // Process frames in parallel batches via fal.ai
  // Reassemble with ffmpeg using -vcodec libvpx-vp9 for WebM alpha

  // Extract frames
  await extractFrames(videoPath, '/tmp/frames/', 30);  // 30fps
  
  // Remove background from each frame in parallel
  const framePaths = await listFiles('/tmp/frames/');
  const batchSize = 10;
  
  for (let i = 0; i < framePaths.length; i += batchSize) {
    const batch = framePaths.slice(i, i + batchSize);
    await Promise.all(batch.map(async (framePath) => {
      const result = await fal.run('fal-ai/bria-rmbg', {
        input: { image_url: await toBase64DataUrl(framePath) }
      });
      await saveImage(result.image.url, framePath.replace('.png', '_nobg.png'));
    }));
  }
  
  // Reassemble into WebM with alpha
  await ffmpeg()
    .input('/tmp/frames/%04d_nobg.png')
    .inputOptions(['-framerate 30'])
    .outputOptions([
      '-c:v libvpx-vp9',
      '-pix_fmt yuva420p',  // yuva = alpha channel
      '-auto-alt-ref 0',
      '-b:v 2M'
    ])
    .output(outputPath)
    .run();
}
```

