## PART 3 — VEO 3 VIDEO GENERATION

### 3.1 What it is

Google Veo 3 generates short video clips from text prompts.
High quality, realistic motion, up to 8 seconds per clip.
Available via Google AI Studio API / Vertex AI.

Use cases in Inkframe:
- Background video scenes (landscape, abstract motion, product shots)
- B-roll footage between diagram scenes
- Atmospheric scene backgrounds (rain, city, abstract)
- Full video scenes (Veo clip IS the scene)

### 3.2 Layer type

```ts
interface Veo3Layer extends BaseLayer {
  type: 'veo3'
  
  // Generation config
  prompt: string
  negativePrompt: string | null
  aspectRatio: '16:9' | '9:16' | '1:1'
  duration: 5 | 8              // seconds (Veo 3 supports 5 or 8)
  
  // Playback
  loop: boolean                // loop the clip if scene is longer
  playbackRate: number         // 0.5-2.0, default 1.0
  
  // Result
  videoUrl: string | null
  thumbnailUrl: string | null
  
  // State
  status: 'pending' | 'generating' | 'ready' | 'error'
  operationName: string | null  // Google AI operation name for polling
}
```

### 3.3 Veo 3 API integration

```ts
// /lib/apis/veo3.ts

// Veo 3 via Google AI Studio (REST API)
const VEO3_BASE = 'https://generativelanguage.googleapis.com/v1beta';

export async function generateVeo3Video(opts: {
  prompt: string
  negativePrompt?: string
  aspectRatio: '16:9' | '9:16' | '1:1'
  durationSeconds: 5 | 8
}): Promise<{ operationName: string }> {
  const response = await fetch(
    `${VEO3_BASE}/models/veo-3.0-generate-preview:generateVideo?key=${process.env.GOOGLE_AI_KEY}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prompt: { text: opts.prompt },
        negativePrompt: opts.negativePrompt,
        generationConfig: {
          mediaResolution: 'MEDIA_RESOLUTION_HIGH',  // 1080p
          aspectRatio: opts.aspectRatio,
          durationSeconds: opts.durationSeconds,
        }
      })
    }
  );
  const data = await response.json();
  return { operationName: data.name };
}

// Poll for completion (Veo takes 2-10 minutes)
export async function getVeo3Status(operationName: string): Promise<{
  done: boolean
  videoUri?: string        // Google Cloud Storage URI when done
  error?: string
}>

// Download from GCS to local cache
export async function downloadVeo3Video(
  gcsUri: string,
  outputPath: string
): Promise<void>
```

