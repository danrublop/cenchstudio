### 4.3 Image generation API

```ts
// /lib/apis/image-gen.ts
import * as fal from '@fal-ai/serverless-client';

const MODEL_IDS: Record<ImageModel, string> = {
  'flux-1.1-pro': 'fal-ai/flux-pro/v1.1',
  'flux-schnell': 'fal-ai/flux/schnell',
  'ideogram-v3': 'fal-ai/ideogram/v3',
  'recraft-v3': 'fal-ai/recraft-v3',
  'stable-diffusion-3': 'fal-ai/stable-diffusion-v3-medium',
  'dall-e-3': null,  // uses OpenAI SDK directly
};

const STYLE_PROMPTS: Record<string, string> = {
  illustration: ', vector illustration style, clean lines',
  flat: ', flat design, simple shapes, minimal',
  sketch: ', pencil sketch, hand-drawn, whiteboard style',
  '3d': ', 3D render, octane render, soft lighting',
  watercolor: ', watercolor illustration, painted',
  photorealistic: ', photorealistic, 4K, detailed',
};

export async function generateImage(opts: {
  prompt: string
  negativePrompt?: string
  model: ImageModel
  aspectRatio: string
  style?: string
}): Promise<{ imageUrl: string, width: number, height: number }> {
  
  const fullPrompt = opts.prompt + (opts.style ? STYLE_PROMPTS[opts.style] ?? '' : '');
  
  if (opts.model === 'dall-e-3') {
    // OpenAI path
    const response = await openai.images.generate({
      model: 'dall-e-3',
      prompt: fullPrompt,
      size: aspectRatioToSize(opts.aspectRatio),
      quality: 'standard',
      n: 1,
    });
    return { imageUrl: response.data[0].url!, width: 1024, height: 1024 };
  }
  
  // fal.ai path
  const result = await fal.run(MODEL_IDS[opts.model], {
    input: {
      prompt: fullPrompt,
      negative_prompt: opts.negativePrompt,
      aspect_ratio: opts.aspectRatio,
      num_inference_steps: opts.model === 'flux-schnell' ? 4 : 28,
      guidance_scale: 3.5,
    }
  });
  
  return {
    imageUrl: result.images[0].url,
    width: result.images[0].width,
    height: result.images[0].height,
  };
}
```

### 4.4 Background removal for stickers

```ts
// /lib/apis/background-removal.ts

export async function removeImageBackground(
  imageUrl: string
): Promise<string> {  // returns data URL with transparency
  
  const result = await fal.run('fal-ai/bria-rmbg', {
    input: {
      image_url: imageUrl,
      sync_mode: true,    // wait for result inline
    }
  });
  
  // Result is PNG with alpha channel
  return result.image.url;
}
```

Cost: ~$0.01 per image for BRIA RMBG. Fast (~2 seconds).

