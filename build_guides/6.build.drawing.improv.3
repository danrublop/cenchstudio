### Tool application

Every animateRough* function accepts `opts.tool`:

```ts
function applyTool(opts: DrawOpts): ResolvedDrawOpts {
  const tool = DRAWING_TOOLS[opts.tool ?? 'marker'];
  return {
    roughness: opts.roughness ?? tool.roughness,
    width: opts.width ?? tool.defaultWidth,
    pressureProfile: opts.pressureOpts ?? tool.pressureProfile,
    alphaJitter: tool.alphaJitter,
    smoothIterations: opts.smoothIterations ?? tool.smoothIterations,
    bowing: tool.bowing,
    lineDash: tool.lineDash,
    lineCap: tool.lineCap,
    // User-specified always wins:
    color: opts.color ?? '#1a1a2e',
    fill: opts.fill ?? null,
    fillAlpha: opts.fillAlpha ?? 0.12,
    seed: opts.seed ?? 1,
  };
}
```

