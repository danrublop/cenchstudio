## IMPROVEMENT 2 — STROKE TEXTURE OVERLAY

Real markers and chalk leave physical texture — slight grain,
ink variation, paper tooth. Simulate this with:

### 2a — Per-stroke alpha jitter

As each segment is drawn, vary the alpha slightly using
seeded randomness. Creates ink variation effect:

```ts
function jitteredAlpha(
  baseAlpha: number,
  t: number,
  rand: () => number,
  intensity: number = 0.08   // how much variation (0 = none, 0.2 = heavy)
): number {
  const jitter = (rand() - 0.5) * 2 * intensity;
  return Math.max(0.3, Math.min(1.0, baseAlpha + jitter));
}
```

Apply per-segment: ctx.globalAlpha = jitteredAlpha(opacity, t, rand, jitter)
where jitter amount varies per tool:
  marker: 0.04   (very slight)
  pen:    0.02   (almost none)
  chalk:  0.15   (heavy variation)
  brush:  0.10   (noticeable)

### 2b — Texture canvas (generate once, reuse)

Generate a noise texture canvas once per scene and composite
it over all canvas2d layers at low opacity:

```ts
function generateTextureCanvas(
  width: number,
  height: number,
  seed: number,
  opts: {
    grainSize?: number    // px, default 1.5
    intensity?: number    // 0-1, default 0.06
    style?: 'grain' | 'paper' | 'chalk'
  } = {}
): HTMLCanvasElement {
  const { grainSize = 1.5, intensity = 0.06, style = 'grain' } = opts;
  const rand = mulberry32(seed);
  const canvas = document.createElement('canvas');
  canvas.width = width;
  canvas.height = height;
  const ctx = canvas.getContext('2d')!;
  
  if (style === 'grain') {
    // Random noise pixels
    const imageData = ctx.createImageData(width, height);
    for (let i = 0; i < imageData.data.length; i += 4) {
      const noise = rand() * 255;
      imageData.data[i] = noise;
      imageData.data[i+1] = noise;
      imageData.data[i+2] = noise;
      imageData.data[i+3] = rand() * intensity * 255;
    }
    ctx.putImageData(imageData, 0, 0);
  }
  
  if (style === 'paper') {
    // Larger grain — simulates paper texture
    for (let x = 0; x < width; x += grainSize) {
      for (let y = 0; y < height; y += grainSize) {
        const v = rand() * intensity;
        ctx.fillStyle = `rgba(0,0,0,${v})`;
        ctx.fillRect(x, y, grainSize, grainSize);
      }
    }
  }
  
  if (style === 'chalk') {
    // Streaky texture — chalk drags across paper
    for (let y = 0; y < height; y += 2) {
      ctx.beginPath();
      ctx.strokeStyle = `rgba(255,255,255,${rand() * intensity * 0.5})`;
      ctx.lineWidth = 1 + rand() * 2;
      ctx.moveTo(0, y + rand() * 2);
      for (let x = 0; x < width; x += 20) {
        ctx.lineTo(x, y + (rand() - 0.5) * 3);
      }
      ctx.stroke();
    }
  }
  
  return canvas;
}
```

In the scene HTML template, after all canvas2d layers render,
composite the texture:

```ts
// Called at end of runAllLayers()
function applyTextureOverlay(
  targetCanvas: HTMLCanvasElement,
  textureStyle: 'grain' | 'paper' | 'chalk',
  seed: number
) {
  const ctx = targetCanvas.getContext('2d')!;
  const texture = generateTextureCanvas(
    targetCanvas.width, targetCanvas.height,
    seed, { style: textureStyle, intensity: 0.05 }
  );
  ctx.save();
  ctx.globalCompositeOperation = 'multiply';
  ctx.globalAlpha = 0.4;
  ctx.drawImage(texture, 0, 0);
  ctx.restore();
}
```

Add `textureStyle` to GlobalStyle:
  'none' | 'grain' | 'paper' | 'chalk'

Default: 'grain' (subtle, works with all tools)

