```

### 7.1 Agent API Route

POST /api/agent — SSE streaming response

Request body:
```ts
{
  message: string
  
  // Agent control (from UI panel)
  agentOverride: 'auto' | 'director' | 'scene-maker' | 'editor' | 'dop'
  modelOverride: string | null      // null = use agent default
  sceneContext: 'all' | string      // scene id for focused context
  activeTools: string[]             // filtered tool types
  
  // Current world state (or just the project id to fetch from DB)
  projectId: string
  
  // Conversation history (last N messages for context)
  history: ChatMessage[]
}
```

Response: SSE stream
```
data: {"type":"thinking","text":"Looking at scene 2..."}
data: {"type":"token","text":"I'll add a canvas2d layer"}
data: {"type":"tool_start","tool":"add_layer","args":{...}}
data: {"type":"tool_complete","tool":"add_layer","result":{...}}
data: {"type":"preview_update","sceneId":"scene-2"}
data: {"type":"token","text":" and then a D3 chart on top."}
data: {"type":"done"}
```

### 7.2 Agent Execution Loop

```ts
async function runAgent(request: AgentRequest): AsyncGenerator<SSEEvent> {
  // 1. Determine which agent to use
  const agent = request.agentOverride === 'auto'
    ? await routeToAgent(request.message, worldState)
    : request.agentOverride;

  // 2. Build context (decision-time guidance)
  const context = buildContext({
    agent,
    sceneContext: request.sceneContext,
    activeTools: request.activeTools,
    worldState,
  });
  // context = { systemPrompt, injectedRules, tools, worldStateSummary }

  // 3. Run Claude with tools
  const stream = anthropic.messages.stream({
    model: request.modelOverride ?? getDefaultModel(agent),
    max_tokens: 4000,
    system: context.systemPrompt,
    tools: context.tools,  // filtered by activeTools
    messages: [
      ...buildWorldStateMessage(context.worldStateSummary),
      ...request.history,
      { role: 'user', content: request.message }
    ]
  });

  // 4. Stream tokens + execute tool calls
  for await (const event of stream) {
    if (event.type === 'content_block_delta') {
      yield { type: 'token', text: event.delta.text };
    }
    if (event.type === 'tool_use') {
      yield { type: 'tool_start', tool: event.name, args: event.input };
      
      // Execute tool, update world state, regenerate HTML
      const result = await executeTool(event.name, event.input);
      await regenerateSceneHTML(result.affectedSceneId);
      
      yield { type: 'tool_complete', tool: event.name, result };
      yield { type: 'preview_update', sceneId: result.affectedSceneId };
      
      // Inject tool result back into context for next tool call
      // (so agent knows what it just did before calling next tool)
    }
  }
}
```

### 7.3 Context Building

```ts
function buildContext(opts: ContextOpts): AgentContext {
  const { agent, sceneContext, activeTools, worldState } = opts;

  // Base system prompt per agent
  const systemPrompt = getAgentSystemPrompt(agent);

  // Inject tool filter constraints
  const disabledTools = ALL_TOOL_TYPES.filter(t => !activeTools.includes(t));
  const toolConstraint = disabledTools.length > 0
    ? `\nDISABLED LAYER TYPES: ${disabledTools.join(', ')}.
       Never generate these types. Achieve all goals with: ${activeTools.join(', ')}.`
    : '';

  // World state: full detail for selected scene, summary for others
  const worldStateSummary = sceneContext === 'all'
    ? summarizeAllScenes(worldState.scenes)
    : {
        focusedScene: getFullSceneDetail(worldState.scenes, sceneContext),
        otherScenes: worldState.scenes
          .filter(s => s.id !== sceneContext)
          .map(summarizeScene)
      };

  // Inject relevant rule files based on active tools + agent type
  const rules = selectRelevantRules(agent, activeTools, worldState);
  const injectedRules = rules.map(r => readRuleFile(r)).join('\n\n');

  // Available tools (filtered)
  const tools = getToolDefinitions(agent, activeTools);

  return {
    systemPrompt: systemPrompt + toolConstraint + '\n\n' + injectedRules,
    tools,
    worldStateSummary
  };
}
```

