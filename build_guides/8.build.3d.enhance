### Component assembly system

Scene code is built by ASSEMBLING components, not generating from scratch:

```ts
// Agent calls:
assemble_three_scene(sceneId, {
  lighting: 'lighting-studio',
  camera: 'camera-orbit-slow',
  objects: ['object-floating-sphere', 'object-data-nodes'],
  environment: 'env-grid-floor',
  customCode: '// any additional code Claude wants to add',
  data: { /* for data-viz components */ }
})
```

This generates scene HTML by composing component build functions:

```ts
function generateThreeSceneFromComponents(config: ThreeSceneConfig): string {
  const lighting = getComponent(config.lighting);
  const camera = getComponent(config.camera);
  const objects = config.objects.map(getComponent);
  const env = config.environment ? getComponent(config.environment) : null;
  
  return `
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, 1920/1080, 0.1, 1000);
    camera.position.set(0, 4, 10);
    
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(1920, 1080);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;
    document.getElementById('${layerId}').appendChild(renderer.domElement);
    
    // LIGHTING
    ${lighting.buildFn}
    const lightingControls = build_lighting_studio(scene, PALETTE);
    
    // CAMERA
    ${camera.buildFn}
    const cameraControls = build_camera_orbit_slow(camera, DURATION);
    
    // ENVIRONMENT
    ${env ? `${env.buildFn}\nconst envControls = build_${env.id.replace(/-/g,'_')}(scene, PALETTE);` : ''}
    
    // OBJECTS
    ${objects.map(obj => `
      ${obj.buildFn}
      const ${obj.id.replace(/-/g,'_')}_controls = build_${obj.id.replace(/-/g,'_')}(scene, PALETTE, ${Math.random() * 1000 | 0});
    `).join('\n')}
    
    // CUSTOM
    ${config.customCode || ''}
    
    // RENDER LOOP
    const startTime = performance.now();
    function animate() {
      const t = (performance.now() - startTime) / 1000;
      if (t > DURATION) return;
      
      lightingControls.update(t);
      cameraControls.update(t);
      ${env ? 'envControls.update(t);' : ''}
      ${objects.map(obj => `${obj.id.replace(/-/g,'_')}_controls.update(t);`).join('\n')}
      
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }
    animate();
  `;
}
```

