export const DEFAULT_THINKING_MODE: Record<string, ThinkingMode> = {
  'auto': 'adaptive',        // let it decide
  'director': 'adaptive',    // planning benefits from thinking
  'scene-maker': 'adaptive', // renderer selection benefits from thinking
  'editor': 'off',           // simple edits don't need thinking
  'dop': 'off',              // style changes don't need thinking
};

