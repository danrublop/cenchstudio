## PART 5 — CHAT MESSAGE COMPONENT

### Thinking block display in chat

Add a ThinkingBlock component for use inside agent messages:

```tsx
// /components/chat/ThinkingBlock.tsx

import { useState } from 'react';
import { ChevronDown, ChevronRight, Brain } from 'lucide-react';

interface ThinkingBlockProps {
  thinking: string;           // the summarized/full thinking text
  isStreaming?: boolean;      // true while still receiving tokens
}

export function ThinkingBlock({
  thinking,
  isStreaming = false,
}: ThinkingBlockProps) {
  const [expanded, setExpanded] = useState(false);

  // Word count for the collapsed summary
  const wordCount = thinking.trim().split(/\s+/).length;

  return (
    <div style={{
      margin: '6px 0',
      borderRadius: 6,
      border: '1px solid #2a2a32',
      overflow: 'hidden',
      fontSize: 11,
      fontFamily: 'DM Mono, monospace',
    }}>
      {/* Header — always visible */}
      <button
        onClick={() => setExpanded(e => !e)}
        style={{
          width: '100%',
          display: 'flex',
          alignItems: 'center',
          gap: 6,
          padding: '6px 10px',
          background: '#1a1a1f',
          border: 'none',
          cursor: 'pointer',
          color: '#6b6b7a',
          textAlign: 'left',
        }}
      >
        <Brain size={11} color="#f59e0b" />
        <span style={{ flex: 1, color: '#9a9aa8' }}>
          {isStreaming
            ? 'Thinking...'
            : `Reasoning (${wordCount} words)`
          }
        </span>
        {!isStreaming && (
          expanded
            ? <ChevronDown size={11} />
            : <ChevronRight size={11} />
        )}
      </button>

      {/* Expanded content */}
      {expanded && !isStreaming && (
        <div style={{
          padding: '8px 12px',
          background: '#111114',
          color: '#9a9aa8',
          lineHeight: 1.6,
          whiteSpace: 'pre-wrap',
          maxHeight: 320,
          overflowY: 'auto',
          borderTop: '1px solid #2a2a32',
          fontSize: 11,
        }}>
          {thinking}
        </div>
      )}

      {/* Streaming indicator */}
      {isStreaming && (
        <div style={{
          padding: '6px 12px',
          background: '#111114',
          borderTop: '1px solid #2a2a32',
          display: 'flex',
          gap: 3,
          alignItems: 'center',
        }}>
          {[0, 1, 2].map(i => (
            <div
              key={i}
              style={{
                width: 4,
                height: 4,
                borderRadius: '50%',
                background: '#f59e0b',
                opacity: 0.6,
                animation: `bounce 1s ${i * 0.15}s infinite`,
              }}
            />
          ))}
        </div>
      )}
    </div>
  );
}
```

