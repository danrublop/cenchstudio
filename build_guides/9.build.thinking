## PART 1 — API LAYER

### Update /lib/agents/base.ts (or wherever Anthropic client calls live)

Add a thinking configuration type and helper:

```ts
import Anthropic from '@anthropic-ai/sdk';

export type ThinkingMode = 'off' | 'adaptive' | 'deep';

export interface AgentCallOptions {
  model: string;
  thinkingMode: ThinkingMode;
  systemPrompt: string;
  messages: Anthropic.MessageParam[];
  tools?: Anthropic.Tool[];
  maxTokens?: number;
}

function buildThinkingConfig(mode: ThinkingMode): {
  thinking?: Anthropic.ThinkingConfigParam;
  temperature?: number;
} {
  switch (mode) {
    case 'off':
      return {};

    case 'adaptive':
      return {
        thinking: { type: 'enabled', budget_tokens: 5000 },
        // Note: temperature must be 1 when thinking is enabled
        // Anthropic API requirement — do not pass temperature
      };

    case 'deep':
      return {
        thinking: { type: 'enabled', budget_tokens: 16000 },
      };
  }
}

// Minimum max_tokens when thinking is enabled
// Must be greater than budget_tokens
function resolveMaxTokens(
  mode: ThinkingMode,
  requested?: number
): number {
  if (mode === 'off') return requested ?? 4000;
  if (mode === 'adaptive') return Math.max(requested ?? 8000, 8000);
  if (mode === 'deep') return Math.max(requested ?? 20000, 20000);
  return requested ?? 4000;
}

export async function* streamAgentResponse(
  opts: AgentCallOptions
): AsyncGenerator<AgentStreamEvent> {
  const anthropic = new Anthropic({
    apiKey: process.env.ANTHROPIC_API_KEY!,
  });

  const thinkingConfig = buildThinkingConfig(opts.thinkingMode);
  const maxTokens = resolveMaxTokens(opts.thinkingMode, opts.maxTokens);

  const streamParams: Anthropic.MessageStreamParams = {
    model: opts.model,
    max_tokens: maxTokens,
    system: opts.systemPrompt,
    messages: opts.messages,
    ...(opts.tools ? { tools: opts.tools } : {}),
    ...(thinkingConfig.thinking
      ? { thinking: thinkingConfig.thinking }
      : {}),
    // Do NOT pass temperature when thinking is enabled
    // Anthropic requires temperature=1 (the default) for thinking
  };

  const stream = anthropic.messages.stream(streamParams);

  let currentBlockType: 'thinking' | 'text' | 'tool_use' | null = null;
  let thinkingBuffer = '';
  let textBuffer = '';

  for await (const event of stream) {
    // Block start
    if (event.type === 'content_block_start') {
      currentBlockType = event.content_block.type as any;

      if (event.content_block.type === 'thinking') {
        yield { type: 'thinking_start' };
      }
      if (event.content_block.type === 'text') {
        yield { type: 'text_start' };
      }
      if (event.content_block.type === 'tool_use') {
        yield {
          type: 'tool_start',
          toolName: event.content_block.name,
          toolId: event.content_block.id,
        };
      }
    }

    // Block delta (streaming content)
    if (event.type === 'content_block_delta') {
      if (event.delta.type === 'thinking_delta') {
        thinkingBuffer += event.delta.thinking;
        yield {
          type: 'thinking_token',
          token: event.delta.thinking,
        };
      }
      if (event.delta.type === 'text_delta') {
        textBuffer += event.delta.text;
        yield {
          type: 'text_token',
          token: event.delta.text,
        };
      }
      if (event.delta.type === 'input_json_delta') {
        yield {
          type: 'tool_input_delta',
          partial: event.delta.partial_json,
        };
      }
    }

    // Block complete
    if (event.type === 'content_block_stop') {
      if (currentBlockType === 'thinking') {
        yield {
          type: 'thinking_complete',
          fullThinking: thinkingBuffer,
        };
        thinkingBuffer = '';
      }
      if (currentBlockType === 'text') {
        yield { type: 'text_complete', fullText: textBuffer };
        textBuffer = '';
      }
      currentBlockType = null;
    }

    // Tool use complete
    if (event.type === 'message_delta') {
      if (event.delta.stop_reason === 'tool_use') {
        yield { type: 'needs_tool' };
      }
    }

    // Final message complete
    if (event.type === 'message_stop') {
      yield { type: 'done' };
    }
  }
}

// Event types emitted by streamAgentResponse
export type AgentStreamEvent =
  | { type: 'thinking_start' }
  | { type: 'thinking_token'; token: string }
  | { type: 'thinking_complete'; fullThinking: string }
  | { type: 'text_start' }
  | { type: 'text_token'; token: string }
  | { type: 'text_complete'; fullText: string }
  | { type: 'tool_start'; toolName: string; toolId: string }
  | { type: 'tool_input_delta'; partial: string }
  | { type: 'needs_tool' }
  | { type: 'done' };
```

