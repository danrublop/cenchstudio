## PART 3 — API ROUTE UPDATE

### Update /app/api/agent/route.ts

Accept thinkingMode in the request body and pass it through:

```ts
export async function POST(req: NextRequest) {
  const body = await req.json();
  const {
    message,
    agentOverride,
    modelOverride,
    thinkingMode = 'adaptive',   // NEW — default adaptive
    sceneContext,
    activeTools,
    projectId,
    history,
  } = body;

  // ... existing routing logic ...

  const stream = streamAgentResponse({
    model: modelOverride ?? getDefaultModel(agent),
    thinkingMode: thinkingMode as ThinkingMode,
    systemPrompt: context.systemPrompt,
    messages: buildMessages(context.worldStateSummary, history, message),
    tools: context.tools,
  });

  // SSE response — forward all events
  const encoder = new TextEncoder();

  return new Response(
    new ReadableStream({
      async start(controller) {
        for await (const event of stream) {
          // Forward thinking events
          if (event.type === 'thinking_start') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({ type: 'thinking_start' })}\n\n`
            ));
          }
          if (event.type === 'thinking_token') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({
                type: 'thinking_token',
                token: event.token
              })}\n\n`
            ));
          }
          if (event.type === 'thinking_complete') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({
                type: 'thinking_complete',
                fullThinking: event.fullThinking
              })}\n\n`
            ));
          }

          // Forward text tokens (existing)
          if (event.type === 'text_token') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({
                type: 'token',
                text: event.token
              })}\n\n`
            ));
          }

          // Forward tool events (existing)
          if (event.type === 'tool_start') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({
                type: 'tool_start',
                tool: event.toolName
              })}\n\n`
            ));
          }

          if (event.type === 'done') {
            controller.enqueue(encoder.encode(
              `data: ${JSON.stringify({ type: 'done' })}\n\n`
            ));
            controller.close();
          }
        }
      }
    }),
    {
      headers: {
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        'Connection': 'keep-alive',
      }
    }
  );
}
```

