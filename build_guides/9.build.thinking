## PART 6 — FRONTEND SSE HANDLER

### Update the chat send handler to process thinking events

In your chat component where you consume the SSE stream:

```tsx
// /components/AgentChat.tsx

async function sendMessage(userMessage: string) {
  // Add user message to chat
  const userMsg: ChatMessage = {
    id: generateId(),
    role: 'user',
    text: userMessage,
    createdAt: new Date(),
  };
  setMessages(prev => [...prev, userMsg]);

  // Add placeholder assistant message
  const assistantId = generateId();
  const assistantMsg: ChatMessage = {
    id: assistantId,
    role: 'assistant',
    text: '',
    agentType: selectedAgent,
    modelUsed: selectedModel,
    thinking: '',
    isThinkingStreaming: false,
    toolCalls: [],
    createdAt: new Date(),
  };
  setMessages(prev => [...prev, assistantMsg]);
  setIsThinking(false);

  // POST to agent API
  const response = await fetch('/api/agent', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      message: userMessage,
      agentOverride: selectedAgent,
      modelOverride: selectedModel,
      thinkingMode,                  // from store
      sceneContext,
      activeTools,
      projectId: currentProjectId,
      history: recentHistory,
    }),
  });

  // Process SSE stream
  const reader = response.body!.getReader();
  const decoder = new TextDecoder();

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;

    const chunk = decoder.decode(value);
    const lines = chunk.split('\n');

    for (const line of lines) {
      if (!line.startsWith('data: ')) continue;
      const data = JSON.parse(line.slice(6));

      switch (data.type) {
        case 'thinking_start':
          setIsThinking(true);
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? { ...m, isThinkingStreaming: true, thinking: '' }
              : m
          ));
          break;

        case 'thinking_token':
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? { ...m, thinking: (m.thinking ?? '') + data.token }
              : m
          ));
          break;

        case 'thinking_complete':
          setIsThinking(false);
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? {
                  ...m,
                  thinking: data.fullThinking,
                  isThinkingStreaming: false,
                }
              : m
          ));
          break;

        case 'token':
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? { ...m, text: m.text + data.text }
              : m
          ));
          break;

        case 'tool_start':
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? {
                  ...m,
                  toolCalls: [
                    ...(m.toolCalls ?? []),
                    { name: data.tool, status: 'running' }
                  ]
                }
              : m
          ));
          break;

        case 'tool_complete':
          setMessages(prev => prev.map(m =>
            m.id === assistantId
              ? {
                  ...m,
                  toolCalls: m.toolCalls?.map(tc =>
                    tc.name === data.tool
                      ? { ...tc, status: 'done' }
                      : tc
                  ) ?? []
                }
              : m
          ));
          break;

        case 'done':
          setIsThinking(false);
          break;
      }
    }
  }
}
```

