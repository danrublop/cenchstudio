## 7. API ROUTE CHANGES

### /api/generate/route.ts

Add type routing:

```ts
const { prompt, sceneId, type, d3Data, previousSummary, style } = await req.json();

if (type === 'svg') {
  // existing streaming SVG logic — unchanged
  return streamingSVGResponse(prompt, style, previousSummary);
}

if (type === 'motion' || type === 'd3' || type === 'three') {
  // Non-streaming: Claude returns JSON, parse it, return it
  const response = await anthropic.messages.create({
    model: 'claude-sonnet-4-20250514',
    max_tokens: 4000,
    system: getSystemPrompt(type, style, previousSummary),
    messages: [{ role: 'user', content: prompt }]
  });
  
  const raw = response.content[0].text;
  const cleaned = raw.replace(/```json|```/g, '').trim();
  const parsed = JSON.parse(cleaned);
  
  return NextResponse.json({ type, result: parsed });
}

if (type === 'lottie') {
  // Generate SVG overlay only
  return streamingSVGResponse(
    `Generate SVG annotations to overlay on a Lottie animation. ${prompt}`,
    style, previousSummary
  );
}
```

### /api/upload/route.ts (extend existing)
Accept .json files in addition to video/audio.
Validate JSON is valid Lottie format by checking for `v`, `w`, `h`, `layers` keys.

