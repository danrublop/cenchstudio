export interface StylePreset {
  // ... existing visual fields ...

  // Export quality
  export: {
    resolution: '720p' | '1080p' | '4k'
    fps: 24 | 30 | 60
    format: 'mp4' | 'webm'
  }

  // Agent behavior
  agent: {
    thinkingMode: ThinkingMode          // default for this style
    planFirst: boolean                  // Director plans before Scene Maker acts
    confirmBeforeBigChanges: boolean    // Editor asks before scene-level changes
    preferredSceneCount: { min: number, max: number }
  }

  // Scene content density
  density: {
    elementsPerScene: { min: number, max: number }
    labelEverything: boolean            // add labels to all diagram elements
    breathingRoom: boolean              // generous whitespace between elements
    annotationStyle: 'minimal' | 'detailed' | 'none'
  }

  // Interactive mode defaults
  interactive: {
    autoAddGates: boolean               // add Continue gates between scenes
    autoAddQuizzes: boolean             // add quiz on key concept scenes
    showProgressBar: boolean
    playerTheme: 'dark' | 'light' | 'transparent'
  }
}
```

