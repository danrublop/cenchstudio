## SYSTEM 2 — GENERATION LOGGING

### 2.1 Database table

Add to /lib/db/schema.ts:

```ts
export const generationLogs = pgTable('generation_logs', {
  id: uuid('id').primaryKey().defaultRandom(),
  projectId: uuid('project_id')
    .references(() => projects.id, { onDelete: 'cascade' }),
  sceneId: uuid('scene_id')
    .references(() => scenes.id, { onDelete: 'set null' }),
  layerId: uuid('layer_id')
    .references(() => layers.id, { onDelete: 'set null' }),

  // The generation context
  userPrompt: text('user_prompt').notNull(),
  systemPromptHash: text('system_prompt_hash'),
  // Hash not full text — full prompt is expensive to store
  // Use the hash to group similar prompts together
  systemPromptSnapshot: text('system_prompt_snapshot'),
  // Store a truncated version (first 500 chars) for debugging

  // What rules/context were injected
  injectedRules: jsonb('injected_rules').$type<string[]>(),
  // e.g. ['core.md', 'canvas2d.md', 'svg.md']

  stylePresetId: text('style_preset_id'),
  agentType: text('agent_type'),
  modelUsed: text('model_used'),
  thinkingMode: text('thinking_mode'),

  // The output
  sceneType: text('scene_type'),
  // What type did the agent choose: svg | canvas2d | d3 | three | zdog
  generatedCodeLength: integer('generated_code_length'),
  // Proxy for complexity

  // Thinking (summarized)
  thinkingContent: text('thinking_content'),
  // The reasoning block content — hugely valuable for analysis

  // Performance
  generationTimeMs: integer('generation_time_ms'),
  inputTokens: integer('input_tokens'),
  outputTokens: integer('output_tokens'),
  thinkingTokens: integer('thinking_tokens'),
  costUsd: real('cost_usd'),

  // Quality signals (updated after generation)
  userAction: text('user_action'),
  // 'kept' | 'regenerated' | 'edited' | 'deleted'
  // Set by frontend when user takes action
  timeToActionMs: integer('time_to_action_ms'),
  // How long between generation completing and user action
  // Short time + regenerated = user immediately disliked it
  editDistance: integer('edit_distance'),
  // Character diff between generated code and final code
  // 0 = kept exactly, large = heavily edited
  userRating: integer('user_rating'),
  // 1-5 if user explicitly rates, null if not rated
  exportSucceeded: boolean('export_succeeded'),
  // Did WVC successfully export this scene?
  exportErrorMessage: text('export_error_message'),

  // Analysis fields (populated by the analysis system)
  qualityScore: real('quality_score'),
  // Computed from signals: 0-1
  // High = kept quickly with no edits
  // Low = regenerated or heavily edited
  analysisNotes: text('analysis_notes'),
  // Free text notes from automated or manual analysis

  createdAt: timestamp('created_at').defaultNow().notNull(),
  updatedAt: timestamp('updated_at').defaultNow().notNull(),
}, (t) => ({
  projectIdx: index('gen_log_project_idx').on(t.projectId),
  modelIdx: index('gen_log_model_idx').on(t.modelUsed),
  presetIdx: index('gen_log_preset_idx').on(t.stylePresetId),
  actionIdx: index('gen_log_action_idx').on(t.userAction),
  createdIdx: index('gen_log_created_idx').on(t.createdAt),
}));
```

### 2.2 Logging in the agent API route

In /app/api/agent/route.ts, wrap the generation call:

```ts
import { createGenerationLog, updateGenerationLog } from
  '@/lib/db/queries/generation-logs';
import { hashString } from '@/lib/utils';

export async function POST(req: NextRequest) {
  const startTime = Date.now();
  const body = await req.json();

  // ... build context, determine agent ...

  // Create log entry before generation starts
  const logId = await createGenerationLog({
    projectId: body.projectId,
    userPrompt: body.message,
    systemPromptHash: hashString(context.systemPrompt),
    systemPromptSnapshot: context.systemPrompt.slice(0, 500),
    injectedRules: context.injectedRuleFiles,
    stylePresetId: project.globalStyle.presetId,
    agentType: agent,
    modelUsed: effectiveModel,
    thinkingMode: body.thinkingMode ?? 'adaptive',
  });

  // Stream the response, collecting metadata
  let totalInputTokens = 0;
  let totalOutputTokens = 0;
  let totalThinkingTokens = 0;
  let thinkingContent = '';
  let chosenSceneType = '';

  const stream = streamAgentResponse({ ... });

  // ... SSE streaming to client ...

  // After generation completes, update the log
  const generationTimeMs = Date.now() - startTime;

  await updateGenerationLog(logId, {
    generationTimeMs,
    inputTokens: totalInputTokens,
    outputTokens: totalOutputTokens,
    thinkingTokens: totalThinkingTokens,
    thinkingContent: thinkingContent.slice(0, 2000),
    // Store first 2000 chars of thinking — enough for analysis
    sceneType: chosenSceneType,
    generatedCodeLength: generatedCode.length,
    costUsd: calculateCost(effectiveModel, {
      input: totalInputTokens,
      output: totalOutputTokens,
      thinking: totalThinkingTokens,
    }),
  });

  // Return logId in the SSE done event so frontend can reference it
  yield { type: 'done', logId };
}
```

### 2.3 Quality signal collection in the frontend

When a user takes action on a generated scene, update the log:

```ts
// In the scene card component — track user actions

// When user clicks Regenerate
async function handleRegenerate(sceneId: string, logId: string) {
  const timeToAction = Date.now() - generationCompletedAt;

  await fetch('/api/generation-log', {
    method: 'PATCH',
    body: JSON.stringify({
      logId,
      userAction: 'regenerated',
      timeToActionMs: timeToAction,
    }),
  });

  // Then trigger new generation
}

// When user keeps the scene (moves on, edits nothing)
// Fire after 30 seconds of inactivity on this scene
function markAsKept(logId: string) {
  fetch('/api/generation-log', {
    method: 'PATCH',
    body: JSON.stringify({
      logId,
      userAction: 'kept',
      timeToActionMs: Date.now() - generationCompletedAt,
    }),
  });
}

// When user edits layer code
async function handleCodeEdit(sceneId: string, layerId: string,
  logId: string, originalCode: string, newCode: string) {

  const editDistance = levenshteinDistance(originalCode, newCode);

  await fetch('/api/generation-log', {
    method: 'PATCH',
    body: JSON.stringify({
      logId,
      userAction: 'edited',
      timeToActionMs: Date.now() - generationCompletedAt,
      editDistance,
    }),
  });
}
```

Simple edit distance for code changes:
```ts
// /lib/utils/edit-distance.ts
// Approximate edit distance — count character differences
// Don't need full Levenshtein, just a rough signal
export function approximateEditDistance(a: string, b: string): number {
  if (a === b) return 0;
  const longer = a.length > b.length ? a : b;
  const shorter = a.length > b.length ? b : a;
  // Count differing chars at same position + length difference
  let diffs = Math.abs(a.length - b.length);
  for (let i = 0; i < shorter.length; i++) {
    if (a[i] !== b[i]) diffs++;
  }
  return diffs;
}
```

### 2.4 Quality score computation

Run this on a schedule (or on-demand) to compute quality scores:

```ts
// /lib/generation-logs/score.ts

export function computeQualityScore(log: GenerationLog): number {
  // No user action yet — can't score
  if (!log.userAction) return -1;

  let score = 0.5; // start neutral

  // User action signals
  if (log.userAction === 'kept') score += 0.3;
  if (log.userAction === 'regenerated') score -= 0.4;
  if (log.userAction === 'deleted') score -= 0.5;
  if (log.userAction === 'edited') score += 0.1;
  // edited = partially good (kept the scene, but needed work)

  // Time to action (faster = stronger signal)
  if (log.timeToActionMs && log.userAction === 'regenerated') {
    if (log.timeToActionMs < 5000) score -= 0.2;
    // Regenerated in under 5 seconds = immediate rejection
  }
  if (log.timeToActionMs && log.userAction === 'kept') {
    if (log.timeToActionMs > 30000) score += 0.1;
    // Kept for 30+ seconds = likely reviewed and approved
  }

  // Edit distance (higher = more rework needed)
  if (log.editDistance) {
    const relativeEdit = log.editDistance / (log.generatedCodeLength ?? 1);
    if (relativeEdit > 0.3) score -= 0.2;  // changed >30% of code
    if (relativeEdit > 0.6) score -= 0.2;  // changed >60% of code
    if (relativeEdit < 0.05) score += 0.1; // barely changed
  }

  // Explicit rating
  if (log.userRating) {
    score += (log.userRating - 3) * 0.1; // 5=+0.2, 4=+0.1, 3=0, 2=-0.1, 1=-0.2
  }

  // Export success
  if (log.exportSucceeded === false) score -= 0.3;
  if (log.exportSucceeded === true) score += 0.1;

  return Math.max(0, Math.min(1, score));
}
```

