# ─── Database ───────────────────────────────────────────
# LOCAL: use Docker Postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inkframe

# CLOUD (Neon): get from neon.tech dashboard
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/inkframe?sslmode=require

# CLOUD (Supabase): get from supabase.com project settings
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inkframe

# local | cloud
STORAGE_MODE=local

# ─── Encryption ─────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption (GitHub tokens, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# ─── App ────────────────────────────────────────────────
# Logged-in project list: include guest (unowned) projects — default true in development only.
# AUTH_LIST_INCLUDES_GUEST_PROJECTS=true

# Set to "true" to use mock agent responses (no API credits used)
MOCK_AGENT=
ANTHROPIC_API_KEY=
FAL_KEY=
HEYGEN_API_KEY=
GOOGLE_AI_KEY=
ELEVENLABS_API_KEY=

# ─── Render server ──────────────────────────────────────
NEXT_PUBLIC_RENDER_SERVER_URL=http://localhost:3001

# ─── Cloud storage (only needed when STORAGE_MODE=cloud) ─
# For storing generated media files (avatars, videos, images)
# Local: files saved to ./public/generated/
# Cloud: upload to S3-compatible storage
# CLOUD_STORAGE_BUCKET=
# CLOUD_STORAGE_REGION=
# CLOUD_STORAGE_ACCESS_KEY=
# CLOUD_STORAGE_SECRET_KEY=
# CLOUD_STORAGE_ENDPOINT=  # for R2/Backblaze, leave empty for AWS S3
