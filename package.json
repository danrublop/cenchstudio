{
  "name": "cench-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dev:electron": "concurrently -k -n tsc,electron -c gray,magenta \"tsc -p electron/tsconfig.json -w\" \"wait-on http://localhost:3000 && wait-on dist-electron/main.js && ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:dev": "npm run dev:electron",
    "build": "next build",
    "start": "next start",
    "server": "node render-server/index.js",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:setup": "npx tsx scripts/setup.ts",
    "canvas-test-scenes": "npx tsx scripts/create-canvas-test-scenes.ts",
    "structured-d3-demo": "npx tsx scripts/create-structured-d3-demo.ts",
    "charts-showcase": "npx tsx scripts/create-charts-showcase-project.ts",
    "avatar-showcase": "npx tsx scripts/create-avatar-showcase-project.ts",
    "mcp": "npx tsx scripts/mcp-server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "vitest",
    "test:ci": "vitest run"
  },
