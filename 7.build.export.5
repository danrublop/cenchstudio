### 2.8 Scene HTML generation with parenting

```ts
function renderLayerTiming(layer: SceneLayer, allLayers: SceneLayer[]): string {
  const absStart = getAbsoluteStartAt(layer, allLayers);
  
  if (layer.type === 'group') return ''; // groups don't render
  
  return `
    setTimeout(async () => {
      // Layer: ${layer.label} (${layer.type})
      // Absolute start: ${absStart}s
      ${layer.generatedCode}
    }, ${absStart * 1000});
  `;
}
```

