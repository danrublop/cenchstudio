// In the element overlay component:
function ElementDragOverlay({ element, onMove, grid, siblings }) {
  const [snapLines, setSnapLines] = useState<SnapLines>({ x: null, y: null });
  
  function handleDrag(clientX, clientY) {
    const rawX = clientXToCanvasX(clientX);
    const rawY = clientYToCanvasY(clientY);
    
    const siblingRects = siblings.map(s => ({
      x: s.x - s.width/2, y: s.y - s.height/2,
      w: s.width, h: s.height
