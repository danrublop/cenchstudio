## IMPROVEMENT 4 — STYLE PRESETS PER SCENE

### 4.1 The concept

Global style sets the project palette/font/roughness.
Scene style overrides specific properties for that scene.
Unoverridden properties inherit from global.

```ts
interface SceneStyleOverride {
  palette?: [string, string, string, string] | null  // null = inherit global
  font?: string | null
  roughnessLevel?: number | null
  bgColor?: string | null
  textureStyle?: string | null
  defaultTool?: DrawToolId | null
}

interface Scene {
  // ... existing fields ...
  styleOverride: SceneStyleOverride
}

// Resolved style (what agents and HTML use)
function resolveSceneStyle(
  scene: Scene,
  globalStyle: GlobalStyle
): GlobalStyle {
  return {
    palette: scene.styleOverride.palette ?? globalStyle.palette,
    font: scene.styleOverride.font ?? globalStyle.font,
    roughnessLevel: scene.styleOverride.roughnessLevel ?? globalStyle.roughnessLevel,
    bgColor: scene.styleOverride.bgColor ?? globalStyle.bgColor,
    textureStyle: scene.styleOverride.textureStyle ?? globalStyle.textureStyle,
    defaultTool: scene.styleOverride.defaultTool ?? globalStyle.defaultTool,
  };
}
```

