## IMPROVEMENT 1 — FRAME-BY-FRAME SCRUBBING

### 1.1 The problem

Current preview: play/pause only. No way to seek to a specific
moment. For timing adjustments the user has to play, pause,
estimate, adjust, repeat. This is the single biggest workflow
pain point for precise animation work.

### 1.2 How it works

The scrub bar maps a pixel position to a timestamp in seconds.
Dragging it seeks the preview to that exact moment.

The challenge: CSS animations and Canvas2D requestAnimationFrame
loops don't support seeking. They run in wall-clock time.
You solve this with animation overriding — rewriting the scene's
time model at load time based on a ?t= query param.

### 1.3 Scene HTML time override

Every scene HTML file already has this at the bottom:

```js
document.addEventListener('DOMContentLoaded', runAllLayers);
```

Add a seek mode that overrides animation time:

```js
// In every scene HTML, before runAllLayers():
const SEEK_TIME = parseFloat(
  new URLSearchParams(location.search).get('t') || '0'
);
const IS_SEEKING = SEEK_TIME > 0;

// Override requestAnimationFrame when seeking
// Instead of running in real time, fast-forward to SEEK_TIME
if (IS_SEEKING) {
  let virtualTime = 0;
  const FRAME_BUDGET = 16; // ms per virtual frame
  const originalRAF = window.requestAnimationFrame.bind(window);
  
  window.requestAnimationFrame = function(callback) {
    if (virtualTime < SEEK_TIME * 1000) {
      // Fast forward: run callback synchronously with virtual time
      virtualTime += FRAME_BUDGET;
      callback(virtualTime);
      // Schedule next virtual frame immediately
      return originalRAF(() => window.requestAnimationFrame(callback));
    } else {
      // Reached seek time — freeze by never calling callback again
      // (or resume normal playback if scrub is released)
      return 0;
    }
  };
  
  // Override setTimeout/setInterval for layer startAt timing
  const originalSetTimeout = window.setTimeout.bind(window);
  window.setTimeout = function(fn, delay, ...args) {
    if (delay <= SEEK_TIME * 1000) {
      // This callback should have already fired — run immediately
      fn(...args);
      return 0;
    }
    // This callback fires after seek time — don't run
    return 0;
  };
  
  // Override CSS animation timing
  // Inject a <style> that sets animation-delay to compensate
  const style = document.createElement('style');
  style.textContent = `
    * {
      animation-delay: calc(var(--original-delay, 0s) - ${SEEK_TIME}s) !important;
      animation-play-state: paused !important;
    }
  `;
  document.head.appendChild(style);
}
```

For SVG layers (stroke-dashoffset animations):
```js
if (IS_SEEKING) {
  // After DOM loaded, fast-forward all SVG animations
  document.querySelectorAll('.stroke, .fadein').forEach(el => {
    const style = window.getComputedStyle(el);
    const delay = parseFloat(style.animationDelay) * 1000;
    const duration = parseFloat(style.animationDuration) * 1000;
    const elapsed = SEEK_TIME * 1000 - delay;
    
    if (elapsed <= 0) {
      // Animation hasn't started yet at seek time
      el.style.animationPlayState = 'paused';
      el.style.animationDelay = '0s';
      el.style.animationIterationCount = '0';
    } else if (elapsed >= duration) {
      // Animation is complete at seek time
      el.style.animationPlayState = 'paused';
      el.style.animationDelay = `-${duration}ms`;
      el.style.animationFillMode = 'forwards';
    } else {
      // Animation is mid-play at seek time
      el.style.animationPlayState = 'paused';
      el.style.animationDelay = `-${elapsed}ms`;
    }
  });
}
```

For Canvas2D layers (the canvas renderer):
```js
// In the inlined canvas renderer, wrap the animation loop:
async function runAllLayers() {
  if (IS_SEEKING) {
    // Run all layers with zero duration (instant render to seek frame)
    // Replace wait() with no-op
    window._inkframe_seeking = true;
    await runLayersInstant(SEEK_TIME);
    window._inkframe_seeking = false;
  } else {
    await runLayersNormal();
  }
}

// In wait() helper:
export function wait(ms: number): Promise<void> {
  if (window._inkframe_seeking) return Promise.resolve(); // skip waits
  return new Promise(r => setTimeout(r, ms));
}

// In all animate* functions:
// If seeking, render final state instantly instead of animating
export async function animateRoughLine(...args): Promise<void> {
  if (window._inkframe_seeking) {
    // Draw complete line instantly at seek-time state
    drawLineComplete(ctx, x1, y1, x2, y2, opts);
    return;
  }
  // Normal animation...
}
```

### 1.4 Scrub bar component

```tsx
// /components/ScrubBar.tsx

interface ScrubBarProps {
  totalDuration: number      // seconds (sum of all scenes)
  scenes: Scene[]            // for scene boundary markers
  currentTime: number        // current playback position
  isPlaying: boolean
  onSeek: (time: number) => void
  onPlayPause: () => void
}

export function ScrubBar({
  totalDuration, scenes, currentTime, isPlaying, onSeek, onPlayPause
}: ScrubBarProps) {
  const barRef = useRef<HTMLDivElement>(null);
  const [isDragging, setIsDragging] = useState(false);
  const [hoverTime, setHoverTime] = useState<number | null>(null);
  
  // Convert pixel position to time
  function pixelToTime(clientX: number): number {
    const bar = barRef.current!;
    const rect = bar.getBoundingClientRect();
    const ratio = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    return ratio * totalDuration;
  }
  
  function handleMouseDown(e: React.MouseEvent) {
    setIsDragging(true);
    onSeek(pixelToTime(e.clientX));
  }
  
  function handleMouseMove(e: React.MouseEvent) {
    setHoverTime(pixelToTime(e.clientX));
    if (isDragging) {
      onSeek(pixelToTime(e.clientX));
    }
  }
  
  // Scene boundary offsets (for marker rendering)
  const sceneOffsets = useMemo(() => {
    let t = 0;
    return scenes.map(s => {
      const offset = t / totalDuration;
      t += s.duration;
      return offset;
    });
  }, [scenes, totalDuration]);
  
  return (
    <div style={{ position: 'relative', userSelect: 'none' }}>
      
      {/* Timecode display */}
      <div style={{ display: 'flex', justifyContent: 'space-between',
                    fontSize: 11, fontFamily: 'monospace',
                    color: '#6b6b7a', marginBottom: 4 }}>
        <span>{formatTimecode(currentTime)}</span>
        {hoverTime !== null && (
          <span style={{ color: '#e84545' }}>
            ▼ {formatTimecode(hoverTime)}
          </span>
        )}
        <span>{formatTimecode(totalDuration)}</span>
      </div>
      
      {/* Main scrub bar */}
      <div
        ref={barRef}
        onMouseDown={handleMouseDown}
        onMouseMove={handleMouseMove}
        onMouseLeave={() => setHoverTime(null)}
        style={{
          height: 8,
          background: '#2a2a32',
          borderRadius: 4,
          cursor: 'pointer',
          position: 'relative',
          overflow: 'visible',
        }}
      >
        {/* Scene color blocks */}
        {scenes.map((scene, i) => (
          <div
            key={scene.id}
            style={{
              position: 'absolute',
              left: `${sceneOffsets[i] * 100}%`,
              width: `${(scene.duration / totalDuration) * 100}%`,
              height: '100%',
              background: SCENE_COLORS[i % SCENE_COLORS.length],
              opacity: 0.3,
              borderRadius: i === 0 ? '4px 0 0 4px' :
                            i === scenes.length-1 ? '0 4px 4px 0' : 0,
            }}
          />
        ))}
        
        {/* Progress fill */}
        <div style={{
          position: 'absolute',
          left: 0,
          width: `${(currentTime / totalDuration) * 100}%`,
          height: '100%',
          background: '#e84545',
          borderRadius: 4,
          opacity: 0.8,
        }} />
        
        {/* Playhead */}
        <div style={{
          position: 'absolute',
          left: `${(currentTime / totalDuration) * 100}%`,
          top: '50%',
          transform: 'translate(-50%, -50%)',
          width: 14,
          height: 14,
          background: '#e84545',
          borderRadius: '50%',
          border: '2px solid white',
          boxShadow: '0 1px 4px rgba(0,0,0,0.4)',
          zIndex: 10,
          cursor: isDragging ? 'grabbing' : 'grab',
        }} />
        
        {/* Scene boundary markers */}
        {sceneOffsets.slice(1).map((offset, i) => (
          <div
            key={i}
            style={{
              position: 'absolute',
              left: `${offset * 100}%`,
              top: -4,
              width: 2,
              height: 16,
              background: '#4a4a52',
              borderRadius: 1,
            }}
          />
        ))}
        
        {/* Hover time indicator */}
        {hoverTime !== null && (
          <div style={{
            position: 'absolute',
            left: `${(hoverTime / totalDuration) * 100}%`,
            top: -24,
            transform: 'translateX(-50%)',
            background: '#1a1a2e',
            color: '#f0ece0',
            padding: '2px 6px',
            borderRadius: 3,
            fontSize: 10,
            fontFamily: 'monospace',
            whiteSpace: 'nowrap',
            pointerEvents: 'none',
          }}>
            {formatTimecode(hoverTime)}
          </div>
        )}
      </div>
      
      {/* Scene labels below bar */}
      <div style={{ position: 'relative', height: 16, marginTop: 2 }}>
        {scenes.map((scene, i) => (
          <div
            key={scene.id}
            style={{
              position: 'absolute',
              left: `${sceneOffsets[i] * 100}%`,
              width: `${(scene.duration / totalDuration) * 100}%`,
              fontSize: 9,
              color: '#6b6b7a',
              textAlign: 'center',
              overflow: 'hidden',
              textOverflow: 'ellipsis',
              whiteSpace: 'nowrap',
              paddingInline: 2,
            }}
          >
            {scene.name || `Scene ${i + 1}`}
          </div>
        ))}
      </div>
    </div>
  );
}

// HH:MM:SS:FF timecode format
function formatTimecode(seconds: number): string {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  const f = Math.floor((seconds % 1) * 30); // frame number at 30fps
  return `${pad(h)}:${pad(m)}:${pad(s)}:${pad(f)}`;
}

function pad(n: number): string {
  return n.toString().padStart(2, '0');
}
```

### 1.5 Seek handler in the preview panel

```tsx
// In the main preview panel component:

const [currentTime, setCurrentTime] = useState(0);
const [isPlaying, setIsPlaying] = useState(false);
const iframeRef = useRef<HTMLIFrameElement>(null);

// Map currentTime to which scene + local time within that scene
function resolveTimeToScene(time: number): { scene: Scene, localTime: number } {
  let t = 0;
  for (const scene of scenes) {
    if (time < t + scene.duration) {
      return { scene, localTime: time - t };
    }
    t += scene.duration;
  }
  return { scene: scenes[scenes.length - 1], localTime: scenes[scenes.length-1].duration };
}

function handleSeek(time: number) {
  setCurrentTime(time);
  setIsPlaying(false);
  
  const { scene, localTime } = resolveTimeToScene(time);
  
  // Reload iframe with ?t=localTime parameter
  // The scene HTML reads this and seeks to that moment
  const sceneUrl = `/scenes/${scene.id}.html?t=${localTime.toFixed(3)}&seed=${scene.seed}`;
  iframeRef.current!.src = sceneUrl;
}

// Playback loop (when playing normally)
useEffect(() => {
  if (!isPlaying) return;
  const interval = setInterval(() => {
    setCurrentTime(t => {
      const next = t + (1/30); // 30fps updates
      if (next >= totalDuration) {
        setIsPlaying(false);
        return 0;
      }
      return next;
    });
  }, 1000/30);
  return () => clearInterval(interval);
}, [isPlaying]);
```

