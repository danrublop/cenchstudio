## IMPROVEMENT 5 — SCENE TEMPLATES

### 5.1 Template data model

```ts
interface SceneTemplate {
  id: string
  name: string
  description: string
  category: TemplateCategory
  tags: string[]
  thumbnail: string              // base64 PNG
  
  // The template content (scene without ids)
  layers: Omit<SceneLayer, 'id'>[]
  duration: number
  styleOverride: SceneStyleOverride
  
  // Metadata
  isBuiltIn: boolean             // true = ships with Inkframe
  isPublic: boolean              // false = user's private template
  authorId: string | null
  useCount: number               // for popularity sorting
  createdAt: string
  
  // Placeholders in generated code
  // ${TITLE}, ${SUBTITLE}, ${BODY} in HTML layers
  // Claude replaces these when instantiating the template
  placeholders: string[]
}

type TemplateCategory =
  | 'title-card'       // opening/closing title slides
  | 'diagram'          // flowcharts, network diagrams
  | 'comparison'       // before/after, side by side
  | 'data'             // charts, graphs, statistics
  | 'process'          // step-by-step, numbered lists
  | 'quote'            // text-heavy, pull quotes
  | 'transition'       // between-section bumpers
  | 'chalkboard'       // dark bg, chalk aesthetic
  | 'technical'        // code, architecture, blueprint
  | 'custom'           // user-created
```

