# Cench Studio endpoints (local)
CENCH_STUDIO_URL=http://localhost:3000
RENDER_SERVER_URL=http://localhost:3001

# Anthropic API key (required — powers the agent LLM)
ANTHROPIC_API_KEY=

# Model override (default: uses project default, typically claude-sonnet-4-6)
# IMESSAGE_MODEL=claude-sonnet-4-6

# TTS, image gen, and audio use free providers only (macOS native TTS, Freesound, etc.)
# localMode is always on — no paid generation APIs besides the Anthropic agent

# Weather API (optional, for daily briefing — has free tier)
WEATHER_API_KEY=

# Contact allowlist (comma-separated phone numbers or Apple IDs)
# If set, only these contacts can trigger the bot. If unset, anyone can.
# ALLOWED_CONTACTS=+15551234567,user@icloud.com

# Agent database path
AGENT_DB_PATH=./data/conversations.db
