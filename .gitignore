# Dependencies
node_modules
render-server/node_modules

# Next.js
.next
# Ignore generated export files but track the Week 1 shell placeholder.
out/*
!out/index.html

# Production
dist

# electron-builder output (installer DMG/exe, never committed)
release/

# Three.js post-effects capture scratch
.tmp-postfx-capture/
three-postfx-showcase.mp4

# Env
.env
.env.local
.env.*.local
.cench.local.json

# Generated files
public/scenes/*.html
public/uploads/*
# Bundled SFX binaries (manifest.json stays tracked; run npm run sfx-library:fetch to fill)
public/sfx-library/**/*.mp3
public/sfx-library/**/*.wav
!public/sfx-library/**/zzfx-*.wav
!public/sfx-library/**/soloud-*.wav
!public/sfx-library/**/react-sounds-*.*
public/sfx-library/**/*.ogg
public/sfx-library/**/*.m4a
!public/sfx-library/manifest.json
public/avatars/*.vrm
public/avatars/*.glb
!public/uploads/.gitkeep
renders/*
!renders/.gitkeep
render-server/tmp/
render-server/.bin/

# Reference repos
reference/

# Misc
.DS_Store
*.pem
npm-debug.log*

# Claude local runtime state
.claude/scheduled_tasks.lock
